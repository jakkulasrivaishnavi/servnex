PORT=5000
NODE_ENV=development

# MongoDB — change to your Atlas URI if not running locally
MONGO_URI=mongodb://localhost:27017/skillbridge

# JWT — change this to any long random string in production
JWT_SECRET=skillbridge_super_secret_jwt_key_change_in_production
JWT_EXPIRE=30d

# Razorpay TEST keys — get free test keys at https://razorpay.com
RAZORPAY_KEY_ID=rzp_test_your_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_secret_here

# Google Maps API key (optional, for map features)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:3000
